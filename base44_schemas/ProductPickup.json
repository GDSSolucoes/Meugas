{
  "name": "ProductPickup",
  "type": "object",
  "properties": {
    "sale_id": {
      "type": "string",
      "description": "ID da venda que gerou a retirada"
    },
    "person_id": {
      "type": "string",
      "description": "ID do cliente"
    },
    "person_name": {
      "type": "string",
      "description": "Nome do cliente"
    },
    "product_id": {
      "type": "string",
      "description": "ID do produto"
    },
    "product_name": {
      "type": "string",
      "description": "Nome do produto"
    },
    "pickup_quantity": {
      "type": "number",
      "description": "Quantidade a retirar"
    },
    "collected_quantity": {
      "type": "number",
      "default": 0,
      "description": "Quantidade j\u00e1 coletada"
    },
    "collected_date": {
      "type": "string",
      "format": "date",
      "description": "Data em que a retirada foi realizada"
    },
    "sale_date": {
      "type": "string",
      "format": "date",
      "description": "Data da venda original"
    },
    "sector_id": {
      "type": "string",
      "description": "ID do setor de onde foi retirado"
    },
    "sector_name": {
      "type": "string",
      "description": "Nome do setor de onde foi retirado"
    },
    "nota_fiscal": {
      "type": "string",
      "description": "N\u00famero da nota fiscal (opcional)"
    },
    "pedido": {
      "type": "string",
      "description": "N\u00famero do pedido (opcional)"
    },
    "status": {
      "type": "string",
      "enum": [
        "pendente",
        "retirado_parcial",
        "retirado_total"
      ],
      "default": "pendente",
      "description": "Status da retirada"
    },
    "company_id": {
      "type": "string",
      "description": "ID da empresa \u00e0 qual o registro pertence"
    },
    "company_name": {
      "type": "string",
      "description": "Nome da empresa \u00e0 qual o registro pertence"
    },
    "created_by_name": {
      "type": "string",
      "description": "Nome do usu\u00e1rio que criou o registro"
    }
  },
  "required": [
    "sale_id",
    "person_id",
    "product_id",
    "pickup_quantity"
  ]
}