{
  "name": "Employee",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nome do funcion\u00e1rio"
    },
    "document": {
      "type": "string",
      "description": "CPF do funcion\u00e1rio"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "phone": {
      "type": "string"
    },
    "position": {
      "type": "string",
      "enum": [
        "vendedor",
        "entregador",
        "gerente",
        "administrativo",
        "outro"
      ],
      "description": "Cargo do funcion\u00e1rio"
    },
    "salary": {
      "type": "number",
      "description": "Sal\u00e1rio"
    },
    "hire_date": {
      "type": "string",
      "format": "date",
      "description": "Data de contrata\u00e7\u00e3o"
    },
    "vacation_start": {
      "type": "string",
      "format": "date",
      "description": "Data de in\u00edcio das f\u00e9rias"
    },
    "vacation_end": {
      "type": "string",
      "format": "date",
      "description": "Data de t\u00e9rmino das f\u00e9rias"
    },
    "company_id": {
      "type": "string",
      "description": "ID da empresa \u00e0 qual o registro pertence"
    },
    "company_name": {
      "type": "string",
      "description": "Nome da empresa \u00e0 qual o registro pertence"
    },
    "created_by_name": {
      "type": "string",
      "description": "Nome do usu\u00e1rio que criou o registro"
    },
    "active": {
      "type": "boolean",
      "default": true,
      "description": "Se o funcion\u00e1rio est\u00e1 ativo ou inativo"
    }
  },
  "required": [
    "name",
    "position"
  ]
}