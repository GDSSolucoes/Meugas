{
  "name": "Facilitador",
  "type": "object",
  "properties": {
    "empresa_id": {
      "type": "string",
      "description": "ID da empresa"
    },
    "nome": {
      "type": "string",
      "description": "Nome do facilitador fiscal / Natureza da opera\u00e7\u00e3o"
    },
    "modelo_fiscal": {
      "type": "string",
      "enum": [
        "55",
        "65"
      ],
      "default": "55",
      "description": "Modelo do documento fiscal (55 = NF-e, 65 = NFC-e)"
    },
    "tipo_operacao": {
      "type": "string",
      "enum": [
        "venda",
        "compra",
        "remessa",
        "retorno",
        "devolucao",
        "transferencia",
        "outras"
      ],
      "description": "Tipo de opera\u00e7\u00e3o fiscal"
    },
    "cfop": {
      "type": "string",
      "description": "CFOP - C\u00f3digo Fiscal de Opera\u00e7\u00f5es"
    },
    "regime_tributario": {
      "type": "string",
      "enum": [
        "simples_nacional",
        "lucro_presumido",
        "lucro_real",
        "mei"
      ],
      "description": "Regime tribut\u00e1rio aplic\u00e1vel"
    },
    "icms_situacao_tributaria": {
      "type": "string",
      "description": "CST ICMS - C\u00f3digo de Situa\u00e7\u00e3o Tribut\u00e1ria"
    },
    "pis_situacao_tributaria": {
      "type": "string",
      "description": "CST PIS"
    },
    "cofins_situacao_tributaria": {
      "type": "string",
      "description": "CST COFINS"
    },
    "ipi_situacao_tributaria": {
      "type": "string",
      "description": "CST IPI"
    },
    "observacoes": {
      "type": "string",
      "description": "Observa\u00e7\u00f5es sobre o facilitador"
    },
    "ativo": {
      "type": "boolean",
      "default": true
    },
    "company_id": {
      "type": "string",
      "description": "ID da empresa \u00e0 qual o registro pertence"
    },
    "company_name": {
      "type": "string",
      "description": "Nome da empresa \u00e0 qual o registro pertence"
    },
    "created_by_name": {
      "type": "string",
      "description": "Nome do usu\u00e1rio que criou o registro"
    }
  },
  "required": [
    "nome",
    "modelo_fiscal",
    "tipo_operacao",
    "cfop",
    "regime_tributario"
  ]
}