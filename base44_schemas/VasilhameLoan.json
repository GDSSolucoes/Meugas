    "sale_id": {
      "type": "string",
      "description": "ID da venda que gerou o empr\u00e9stimo"
    },
    "person_id": {
      "type": "string",
      "description": "ID do cliente"
    },
    "person_name": {
      "type": "string",
      "description": "Nome do cliente"
    },
    "vasilhame_id": {
      "type": "string",
      "description": "ID do vasilhame emprestado"
    },
    "vasilhame_name": {
      "type": "string",
      "description": "Nome do vasilhame emprestado"
    },
    "loan_quantity": {
      "type": "number",
      "description": "Quantidade de vasilhames emprestados"
    },
    "returned_quantity": {
