{
  "name": "Person",
  "type": "object",
  "properties": {
    "person_number": {
      "type": "string",
      "description": "N\u00famero sequencial da pessoa (c\u00f3digo do cliente)"
    },
    "name": {
      "type": "string",
      "description": "Nome da pessoa/empresa"
    },
    "document": {
      "type": "string",
      "description": "CPF/CNPJ"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "phone": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Lista de telefones"
    },
    "type": {
      "type": "string",
      "enum": [
        "cliente",
        "fornecedor",
        "ponto_venda",
        "conveniada"
      ],
      "description": "Tipo de pessoa"
    },
    "address": {
      "type": "object",
      "properties": {
        "street": {
          "type": "string",
          "description": "Rua/Logradouro"
        },
        "number": {
          "type": "string",
          "description": "N\u00famero do im\u00f3vel"
        },
        "complement": {
          "type": "string",
          "description": "Complemento do endere\u00e7o (apartamento, bloco, etc)"
        },
        "neighborhood": {
          "type": "string",
          "description": "Bairro"
        },
        "reference_point": {
          "type": "string",
          "description": "Ponto de refer\u00eancia"
        },
        "city": {
          "type": "string"
        },
        "state": {
          "type": "string"
        },
        "zipcode": {
          "type": "string"
        }
      }
    },
    "glp_consumption_days": {
      "type": [
        "number",
        "null"
      ],
      "description": "Consumo de GLP em dias (frequ\u00eancia de troca do botij\u00e3o)"
    },
    "birthday": {
      "type": [
        "string",
        "null"
      ],
      "format": "date",
      "description": "Data de anivers\u00e1rio"
    },
    "conveniada_id": {
      "type": "string",
      "description": "ID da empresa conveniada (se aplic\u00e1vel)"
    },
    "conveniada_name": {
      "type": "string",
      "description": "Nome da empresa conveniada (se aplic\u00e1vel)"
    },
    "company_id": {
      "type": "string",
      "description": "ID da empresa \u00e0 qual o registro pertence"
    },
    "company_name": {
      "type": "string",
      "description": "Nome da empresa \u00e0 qual o registro pertence"
    },
    "created_by_name": {
      "type": "string",
      "description": "Nome do usu\u00e1rio que criou o registro"
    },
    "active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "name",
    "type"
  ]
}