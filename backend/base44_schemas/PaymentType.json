{
  "name": "PaymentType",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nome da forma de pagamento (ex: Dinheiro, Cart\u00e3o de Cr\u00e9dito)"
    },
    "type": {
      "type": "string",
      "enum": [
        "dinheiro",
        "pix",
        "cartao_debito",
        "cartao_credito",
        "boleto",
        "cheque",
        "convenio"
      ],
      "description": "Tipo de pagamento"
    },
    "max_installments": {
      "type": "number",
      "default": 1,
      "description": "N\u00famero m\u00e1ximo de parcelas permitidas"
    },
    "days_interval": {
      "type": "number",
      "default": 30,
      "description": "Intervalo em dias entre parcelas"
    },
    "acquirer_id": {
      "type": "string",
      "description": "Vínculo opcional com a adquirente para tipos de cartão"
    },
    "company_id": {
      "type": "string",
      "description": "ID da empresa \u00e0 qual o registro pertence"
    },
    "company_name": {
      "type": "string",
      "description": "Nome da empresa \u00e0 qual o registro pertence"
    },
    "created_by_name": {
      "type": "string",
      "description": "Nome do usu\u00e1rio que criou o registro"
    },
    "active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "name",
    "type"
  ]
}