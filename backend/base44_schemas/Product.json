{
  "name": "Product",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nome do produto"
    },
    "code": {
      "type": "string",
      "description": "C\u00f3digo interno do produto"
    },
    "category": {
      "type": "string",
      "enum": [
        "equipamento",
        "acessorio",
        "glp",
        "agua",
        "vasilhame",
        "outros"
      ]
    },
    "unit_price": {
      "type": "number",
      "description": "Pre\u00e7o de Venda"
    },
    "cost_price": {
      "type": "number",
      "description": "Pre\u00e7o de Custo",
      "default": 0
    },
    "min_stock": {
      "type": "number",
      "default": 10
    },
    "vasilhame_id": {
      "type": "string",
      "description": "ID do vasilhame associado (para produtos GLP e AGUA)"
    },
    "vasilhame_name": {
      "type": "string",
      "description": "Nome do vasilhame associado (para produtos GLP e AGUA)"
    },
    "ncm": {
      "type": "string",
      "description": "NCM - Nomenclatura Comum do Mercosul"
    },
    "cest": {
      "type": "string",
      "description": "CEST - C\u00f3digo Especificador da Substitui\u00e7\u00e3o Tribut\u00e1ria"
    },
    "unidade_tributavel": {
      "type": "string",
      "default": "UN",
      "description": "Unidade tribut\u00e1vel (UN, KG, M, etc)"
    },
    "icms_origem": {
      "type": "string",
      "enum": [
        "0",
        "1",
        "2",
        "3",
        "4",
        "5",
        "6",
        "7",
        "8"
      ],
      "default": "0",
      "description": "Origem da mercadoria (0=Nacional, 1=Estrangeira-Importa\u00e7\u00e3o direta, etc)"
    },
    "beneficio_fiscal": {
      "type": "string",
      "description": "C\u00f3digo do benef\u00edcio fiscal aplic\u00e1vel ao produto (se houver)"
    },
    "anp_codigo": {
      "type": "string",
      "description": "C\u00f3digo ANP - Ag\u00eancia Nacional do Petr\u00f3leo"
    },
    "anp_descricao": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o ANP"
    },
    "valor_sem_icms_kg": {
      "type": "number",
      "default": 0,
      "description": "R$/KG sem ICMS"
    },
    "kg_por_unidade_glp": {
      "type": "number",
      "default": 0,
      "description": "KG/UN GLP"
    },
    "percentual_glp": {
      "type": "number",
      "default": 0,
      "description": "% de GLP"
    },
    "percentual_gn_nacional": {
      "type": "number",
      "default": 0,
      "description": "% GN Nacional"
    },
    "percentual_gn_importado": {
      "type": "number",
      "default": 0,
      "description": "% GN Importado"
    },
    "codif": {
      "type": "string",
      "description": "CODIF - C\u00f3digo de autoriza\u00e7\u00e3o de comercializa\u00e7\u00e3o"
    },
    "peso_liquido": {
      "type": "number",
      "default": 0,
      "description": "Peso L\u00edquido em KG"
    },
    "peso_bruto": {
      "type": "number",
      "default": 0,
      "description": "Peso Bruto em KG"
    },
    "informacoes_adicionais_nfe": {
      "type": "string",
      "description": "Informa\u00e7\u00f5es adicionais para NFe"
    },
    "company_id": {
      "type": "string",
      "description": "ID da empresa \u00e0 qual o registro pertence"
    },
    "company_name": {
      "type": "string",
      "description": "Nome da empresa \u00e0 qual o registro pertence"
    },
    "created_by_name": {
      "type": "string",
      "description": "Nome do usu\u00e1rio que criou o registro"
    },
    "active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "name",
    "unit_price"
  ]
}