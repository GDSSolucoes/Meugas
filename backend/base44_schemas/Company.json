{
  "name": "Company",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nome da empresa"
    },
    "document": {
      "type": "string",
      "description": "CNPJ da empresa"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email principal da empresa"
    },
    "phone": {
      "type": "string",
      "description": "Telefone principal da empresa"
    },
    "address": {
      "type": "object",
      "properties": {
        "street": {
          "type": "string"
        },
        "number": {
          "type": "string"
        },
        "complement": {
          "type": "string"
        },
        "neighborhood": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "state": {
          "type": "string"
        },
        "zipcode": {
          "type": "string"
        },
        "codigo_municipio": {
          "type": "string",
          "description": "C\u00f3digo IBGE do munic\u00edpio"
        }
      }
    },
    "parametros_fiscais": {
      "type": "object",
      "properties": {
        "cnpj": {
          "type": "string"
        },
        "razao_social": {
          "type": "string"
        },
        "inscricao_estadual": {
          "type": "string"
        },
        "regime_tributario": {
          "type": "string",
          "enum": [
            "simples_nacional",
            "lucro_presumido",
            "lucro_real",
            "mei"
          ]
        },
        "ambiente_nfe": {
          "type": "string",
          "enum": [
            "homologacao",
            "producao"
          ],
          "default": "homologacao"
        },
        "emitir_nfe": {
          "type": "boolean",
          "default": true
        },
        "emitir_nfce": {
          "type": "boolean",
          "default": true
        },
        "serie_nfe": {
          "type": "number",
          "default": 1
        },
        "serie_nfce": {
          "type": "number",
          "default": 1
        },
        "numero_inicial_nfe": {
          "type": "number",
          "default": 1
        },
        "numero_inicial_nfce": {
          "type": "number",
          "default": 1
        },
        "observacoes_nfe": {
          "type": "string"
        },
        "observacoes_nfce": {
          "type": "string"
        }
      }
    },
    "plan_type": {
      "type": "string",
      "enum": [
        "basic",
        "premium",
        "enterprise"
      ],
      "default": "basic",
      "description": "Tipo de plano contratado"
    },
    "monthly_fee": {
      "type": "number",
      "description": "Valor da mensalidade"
    },
    "due_date": {
      "type": "string",
      "format": "date",
      "description": "Data de vencimento da mensalidade"
    },
    "status": {
      "type": "string",
      "enum": [
        "ativa",
        "inativa",
        "suspensa_pagamento"
      ],
      "default": "ativa",
      "description": "Status da empresa"
    },
    "suspension_reason": {
      "type": "string",
      "description": "Motivo da suspens\u00e3o"
    },
    "admin_name": {
      "type": "string",
      "description": "Nome do administrador principal da empresa"
    },
    "admin_email": {
      "type": "string",
      "format": "email",
      "description": "Email do administrador principal da empresa"
    },
    "created_by_name": {
      "type": "string",
      "description": "Nome do usu\u00e1rio que criou o registro"
    },
    "notes": {
      "type": "string",
      "description": "Observa\u00e7\u00f5es sobre a empresa"
    }
  },
  "required": [
    "name",
    "document",
    "email",
    "admin_name",
    "admin_email"
  ]
}