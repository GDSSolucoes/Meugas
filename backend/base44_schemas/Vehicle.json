{
  "name": "Vehicle",
  "type": "object",
  "properties": {
    "plate": {
      "type": "string",
      "description": "Placa do ve\u00edculo"
    },
    "fleet_number": {
      "type": "string",
      "description": "N\u00famero da frota"
    },
    "type": {
      "type": "string",
      "enum": [
        "carro",
        "moto",
        "caminhao",
        "van",
        "utilitario",
        "outro"
      ],
      "description": "Tipo do ve\u00edculo"
    },
    "description": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o do ve\u00edculo (marca/modelo)"
    },
    "year": {
      "type": "number",
      "description": "Ano do ve\u00edculo"
    },
    "color": {
      "type": "string",
      "description": "Cor do ve\u00edculo"
    },
    "initial_km": {
      "type": "number",
      "default": 0,
      "description": "Quilometragem inicial"
    },
    "company_id": {
      "type": "string",
      "description": "ID da empresa \u00e0 qual o registro pertence"
    },
    "company_name": {
      "type": "string",
      "description": "Nome da empresa \u00e0 qual o registro pertence"
    },
    "created_by_name": {
      "type": "string",
      "description": "Nome do usu\u00e1rio que criou o registro"
    },
    "active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "plate",
    "type",
    "description"
  ]
}