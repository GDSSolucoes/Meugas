{
  "name": "Order",
  "type": "object",
  "properties": {
    "order_number": {
      "type": "string",
      "description": "N\u00famero do pedido"
    },
    "person_id": {
      "type": "string",
      "description": "ID da pessoa (cliente)"
    },
    "person_name": {
      "type": "string",
      "description": "Nome do cliente"
    },
    "person_address": {
      "type": "object",
      "properties": {
        "street": {
          "type": "string"
        },
        "number": {
          "type": "string"
        },
        "neighborhood": {
          "type": "string"
        },
        "reference_point": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "state": {
          "type": "string"
        },
        "zipcode": {
          "type": "string"
        }
      },
      "description": "C\u00f3pia do endere\u00e7o do cliente no momento do pedido"
    },
    "employee_id": {
      "type": "string",
      "description": "ID do funcion\u00e1rio entregador"
    },
    "employee_name": {
      "type": "string",
      "description": "Nome do funcion\u00e1rio entregador"
    },
    "payment_type_id": {
      "type": "string",
      "description": "ID da forma de pagamento"
    },
    "payment_type_name": {
      "type": "string",
      "description": "Nome da forma de pagamento"
    },
    "cash_account_id": {
      "type": "string",
      "description": "ID da conta/caixa para pagamento \u00e0 vista"
    },
    "cash_account_name": {
      "type": "string",
      "description": "Nome da conta/caixa para pagamento \u00e0 vista"
    },
    "status": {
      "type": "string",
      "enum": [
        "pendente",
        "em_atendimento",
        "finalizado",
        "cancelado"
      ],
      "default": "pendente"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "product_id": {
            "type": "string"
          },
          "product_name": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "unit_price": {
            "type": "number"
          },
          "discount": {
            "type": "number",
            "default": 0,
            "description": "Valor do desconto no item"
          },
          "total": {
            "type": "number"
          }
        }
      }
    },
    "total_amount": {
      "type": "number",
      "default": 0
    },
    "delivery_date": {
      "type": "string",
      "format": "date"
    },
    "notes": {
      "type": "string"
    },
    "attended_at": {
      "type": "string",
      "format": "date-time",
      "description": "Data e hora que o pedido foi para atendimento"
    },
    "finalized_at": {
      "type": "string",
      "format": "date-time",
      "description": "Data e hora que o pedido foi finalizado"
    },
    "cancelled_at": {
      "type": "string",
      "format": "date-time",
      "description": "Data e hora que o pedido foi cancelado"
    },
    "cancellation_reason": {
      "type": "string",
      "description": "Motivo do cancelamento do pedido"
    },
    "company_id": {
      "type": "string",
      "description": "ID da empresa \u00e0 qual o registro pertence"
    },
    "company_name": {
      "type": "string",
      "description": "Nome da empresa \u00e0 qual o registro pertence"
    },
    "created_by_name": {
      "type": "string",
      "description": "Nome do usu\u00e1rio que criou o registro"
    }
  },
  "required": [
    "order_number",
    "person_id"
  ]
}