{
  "name": "CashAccount",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nome da conta/caixa (ex: Caixa Principal, Banco X)"
    },
    "type": {
      "type": "string",
      "enum": [
        "caixa_fisico",
        "conta_bancaria"
      ],
      "description": "Tipo de conta"
    },
    "balance": {
      "type": "number",
      "default": 0,
      "description": "Saldo atual da conta"
    },
    "initial_balance": {
      "type": "number",
      "default": 0,
      "description": "Saldo inicial"
    },
    "initial_balance_date": {
      "type": "string",
      "format": "date",
      "description": "Data do saldo inicial"
    },
    "company_id": {
      "type": "string",
      "description": "ID da empresa \u00e0 qual o registro pertence"
    },
    "company_name": {
      "type": "string",
      "description": "Nome da empresa \u00e0 qual o registro pertence"
    },
    "created_by_name": {
      "type": "string",
      "description": "Nome do usu\u00e1rio que criou o registro"
    },
    "active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "name",
    "type"
  ]
}